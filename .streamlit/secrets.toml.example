# Streamlit Cloud secrets — OPTIONAL.
#
# The AI Command Center is designed to run with NO secrets at all in
# offline mode. Deploy it that way first and confirm everything works
# before considering enabling live Bedrock reasoning below.
#
# Copy this file to .streamlit/secrets.toml (NOT committed) and paste
# the contents into Streamlit Cloud → App settings → Secrets.

# === Mandatory for the public demo ===
RUN_MODE = "offline"

# === Optional: enable live Bedrock reasoning ===
# Set RUN_MODE = "" (or remove it) to allow Bedrock when these are set.
# BEDROCK_MODEL_ID = "anthropic.claude-3-haiku-20240307-v1:0"
# AWS_ACCESS_KEY_ID = ""
# AWS_SECRET_ACCESS_KEY = ""
# AWS_REGION = "ap-south-1"

# === Optional: Athena live mode (NOT recommended for the public demo) ===
# ATHENA_DATABASE = "jiohotstar_gold"
# ATHENA_OUTPUT_LOCATION = "s3://your-bucket/athena-results/"
# ATHENA_WORKGROUP = "primary"
